# Copy values into your shell or local environment manager.
# Do not rename this file to .env with real secrets and commit it.

# Required by default. Set the same value in the Streamlit app terminal and
# the busternet_sidecar terminal.
BUSTERNET_TOKEN=replace-with-a-long-random-token

# Keep token enforcement enabled except for isolated classroom debugging.
DIFD_REQUIRE_SIDECAR_TOKEN=1

# Optional local policy overrides. Defaults are NIST-aligned for this project.
DIFD_MIN_PASSWORD_LENGTH=15
DIFD_SESSION_TIMEOUT_SECONDS=3600
DIFD_LOCKOUT_THRESHOLD=5
DIFD_LOCKOUT_SECONDS=900
